# ============================================================
# ModernPLP — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----- API Configuration -----
# Base URL for the product API
# Default: Fake Store API (https://fakestoreapi.com)
# Replace with your custom REST API endpoint
NEXT_PUBLIC_API_URL=https://fakestoreapi.com

# ----- Pagination -----
# Number of products to display per page
NEXT_PUBLIC_PRODUCTS_PER_PAGE=12

# ----- Site Configuration -----
# Your production site URL (used for canonical URLs and OG tags)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# ----- Analytics (Optional) -----
# Google Analytics measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----- Feature Flags (Optional) -----
# Enable/disable skeleton loaders
# NEXT_PUBLIC_ENABLE_SKELETONS=true
