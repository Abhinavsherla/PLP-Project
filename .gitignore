# ============================================================
# ModernPLP — .gitignore
# ============================================================

# ----- Dependencies -----
node_modules/
/.pnp
.pnp.js

# ----- Next.js Build Output -----
/.next/
/out/
/build/

# ----- Production -----
/dist/

# ----- Debug -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Environment Variables -----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example so others know what vars are needed
!.env.example

# ----- Vercel -----
.vercel

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- OS Generated -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- IDE / Editor -----
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ----- Testing -----
/coverage/
.nyc_output/

# ----- Miscellaneous -----
*.tgz
*.log
.cache/
